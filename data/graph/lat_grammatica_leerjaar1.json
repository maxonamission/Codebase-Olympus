      "id": "LAT-G-SYNT-VOC-FUNCTIE",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Functie van de vocativus",
      "titel_terminologie": "casus vocativus",
      "beschrijving": "De vocativus is de naamval van de aanspreekvorm. Wordt gebruikt om iemand direct aan te spreken, bijv. 'Marce!' (Marcus!). Vaak gelijk aan de nominativus, behalve bij de 2e declinatie sg. (-e).",
      "bloom_niveau": "kennis",
      "fase": "onderbouw_1",
      "toetsbaar": true,

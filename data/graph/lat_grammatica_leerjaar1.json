      "type": "G",
      "taal": "lat",
      "titel_nl": "Meewerkend voorwerp",
      "titel_terminologie": "obiectum indirectum",
      "beschrijving": "Het meewerkend voorwerp (obiectum indirectum) is het zinsdeel dat aangeeft aan wie of voor wie de handeling plaatsvindt. Staat in het Latijn in de dativus, bijv. 'puellae dat' (hij geeft aan het meisje).",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",

    },
    {
      "id": "LAT-G-MORF-DECL2-NEUT",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Neutrum 2e declinatie (-um)",
      "titel_terminologie": "neutra in -um",
      "beschrijving": "Neutra van de 2e declinatie: nominativus sg. op -um (bellum, templum). Neutrumregel: nom.=acc. in alle numeri; pl. nom./acc. altijd op -a.",
      "bloom_niveau": "toepassing",

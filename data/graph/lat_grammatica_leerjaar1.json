      "items": []
    },
    {
      "id": "LAT-G-MORF-STAM-INTRO",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Wat is een woordstam?",
      "titel_terminologie": "stirps",
      "beschrijving": "De woordstam is het onveranderlijke deel van een woord dat de basisbetekenis draagt. Bij verbuiging en vervoeging blijft de stam gelijk; alleen de uitgang verandert.",
      "bloom_niveau": "kennis",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-UIT-INTRO",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Wat is een uitgang?",
      "titel_terminologie": "terminatio",
      "beschrijving": "De uitgang is het veranderlijke deel achter de woordstam. Bij zelfstandige naamwoorden drukt de uitgang naamval en getal uit; bij werkwoorden persoon, getal en tijd.",
      "bloom_niveau": "kennis",
      "fase": "onderbouw_1",

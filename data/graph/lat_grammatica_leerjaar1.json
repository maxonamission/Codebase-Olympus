    },
    {
      "id": "LAT-G-SYNT-SUBJ",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Onderwerp",
      "titel_terminologie": "subiectum",
      "beschrijving": "Het onderwerp (subiectum) is het zinsdeel dat aangeeft wie of wat de handeling verricht. Staat in het Latijn in de nominativus en is congruent met de persoonsvorm.",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",

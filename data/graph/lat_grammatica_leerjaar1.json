{
  "knopen": [
    {
      "id": "LAT-G-SYNT-VOC-FUNCTIE",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Functie van de vocativus",
      "titel_terminologie": "casus vocativus",
      "beschrijving": "De vocativus als naamval van de aanspreekvorm: wordt gebruikt om iemand direct aan te spreken, bijv. 'Marce!' Vaak gelijk aan de nominativus, behalve bij de 2e declinatie sg. (-e).",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-STAM-INTRO",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Wat is een woordstam?",
      "titel_terminologie": "stirps",
      "beschrijving": "De woordstam is het onveranderlijke deel van een woord dat de basisbetekenis draagt. Bij verbuiging en vervoeging blijft de stam gelijk; alleen de uitgang verandert.",
      "bloom_niveau": "kennis",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-UIT-INTRO",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Wat is een uitgang?",
      "titel_terminologie": "terminatio",
      "beschrijving": "De uitgang is het veranderlijke deel achter de woordstam. Bij zelfstandige naamwoorden drukt de uitgang naamval en getal uit; bij werkwoorden persoon, getal en tijd.",
      "bloom_niveau": "kennis",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-SYNT-SUBJ",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Onderwerp",
      "titel_terminologie": "subiectum",
      "beschrijving": "Het onderwerp (subiectum) is het zinsdeel dat aangeeft wie of wat de handeling verricht. Staat in het Latijn in de nominativus en is congruent met de persoonsvorm.",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-SYNT-OBJDIR",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Lijdend voorwerp",
      "titel_terminologie": "obiectum directum",
      "beschrijving": "Het lijdend voorwerp (obiectum directum) is het zinsdeel dat de handeling ondergaat. Staat in het Latijn in de accusativus, bijv. 'puellam videt' (hij ziet het meisje).",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-SYNT-OBJIND",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Meewerkend voorwerp",
      "titel_terminologie": "obiectum indirectum",
      "beschrijving": "Het meewerkend voorwerp (obiectum indirectum) is het zinsdeel dat aangeeft aan wie of voor wie de handeling plaatsvindt. Staat in het Latijn in de dativus, bijv. 'puellae dat' (hij geeft aan het meisje).",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-VOC-D1",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Vocativus 1e declinatie",
      "titel_terminologie": "vocativus declinationis primae",
      "beschrijving": "De vocativus van de 1e declinatie is gelijk aan de nominativus: sg. -a, pl. -ae. Bijv. puella! (meisje!), puellae! (meisjes!).",
      "bloom_niveau": "toepassing",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-DECL1-STAM",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Stam bepalen 1e declinatie",
      "titel_terminologie": "stirps declinationis primae",
      "beschrijving": "De stam van een 1e-declinatiewoord vind je door -ae van de genitivus singularis af te halen. Bijv. puell-ae → stam puell-. Aan deze stam plak je de naamvalsuitgangen.",
      "bloom_niveau": "toepassing",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-DECL1-MASC",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Masculina 1e declinatie",
      "titel_terminologie": "masculina declinationis primae",
      "beschrijving": "Enkele mannelijke woorden volgen de 1e declinatie: nauta (zeeman), poeta (dichter), pirata (piraat), agricola (boer). Ze verbuigen identiek aan feminina maar zijn masculinum.",
      "bloom_niveau": "toepassing",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-DECL1-PARAD",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Paradigma 1e declinatie",
      "titel_terminologie": "paradigma declinationis primae",
      "beschrijving": "Het volledige verbuigingsoverzicht van de 1e declinatie. Modelwoord: puella, -ae (v.) — alle zes naamvallen in enkelvoud en meervoud.",
      "bloom_niveau": "toepassing",
      "fase": "onderbouw_1",
      "toetsbaar": true,
      "pensum_jaren": [],
      "items": []
    },
    {
      "id": "LAT-G-MORF-DECL2-STAM",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Stam bepalen 2e declinatie",
      "titel_terminologie": "stirps declinationis secundae",
      "beschrijving": "De stam van een 2e-declinatiewoord vind je door -i van de genitivus singularis af te halen. Bijv. domin-i → stam domin-, bell-i → stam bell-.",
      "bloom_niveau": "toepassing",
      "fase": "onderbouw_1",
      "toetsbaar": true,

      "items": []
    },
    {
      "id": "LAT-G-MORF-DECL2-MASC",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Masculinum 2e declinatie (-us)",
      "titel_terminologie": "masculina in -us",
      "beschrijving": "Het hoofdpatroon van de 2e declinatie masculinum: nominativus sg. op -us (dominus, servus, amicus). Modelwoord: dominus, -i (m.).",
      "bloom_niveau": "toepassing",
      "fase": "onderbouw_1",
      "toetsbaar": true,

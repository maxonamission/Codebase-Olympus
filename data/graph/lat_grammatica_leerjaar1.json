      "type": "G",
      "taal": "lat",
      "titel_nl": "Lijdend voorwerp",
      "titel_terminologie": "obiectum directum",
      "beschrijving": "Het lijdend voorwerp (obiectum directum) is het zinsdeel dat de handeling ondergaat. Staat in het Latijn in de accusativus, bijv. 'puellam videt' (hij ziet het meisje).",
      "bloom_niveau": "begrip",
      "fase": "onderbouw_1",
      "toetsbaar": true,

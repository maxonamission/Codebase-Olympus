    },
    {
      "id": "LAT-G-MORF-DECL2-ER",
      "type": "G",
      "taal": "lat",
      "titel_nl": "Masculinum 2e declinatie (-er)",
      "titel_terminologie": "masculina in -er",
      "beschrijving": "Variant van de 2e declinatie: nominativus sg. op -er. Twee subtypen: puer, pueri (stam behoudt -e-) en ager, agri (stam verliest -e-). Genitivus toont de ware stam.",
      "bloom_niveau": "toepassing",
